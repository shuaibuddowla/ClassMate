<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/cm_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Study Material"
                android:textColor="@color/cm_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <!-- Title field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Document Title"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/cm_primary"
            app:hintTextColor="@color/cm_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:inputType="textCapWords"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Subject dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Select Subject"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/cm_primary"
            app:hintTextColor="@color/cm_primary">

            <AutoCompleteTextView
                android:id="@+id/dropdownSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/cm_text_primary"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Course Code"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/cm_primary"
            app:hintTextColor="@color/cm_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCourseCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:inputType="textCapCharacters" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description (optional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="@color/cm_primary"
            app:hintTextColor="@color/cm_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:inputType="textMultiLine"
                android:minLines="2"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mode Selector -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnModeGithub"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnModeGithub"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GitHub"
                android:textColor="@color/cm_text_primary"/>

            <Button
                android:id="@+id/btnModeTelegram"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Telegram"
                android:textColor="@color/cm_text_primary"/>

            <Button
                android:id="@+id/btnModeDrive"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LINK"
                android:textColor="@color/cm_text_primary"/>

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- File picker (GitHub Mode) -->
        <LinearLayout
            android:id="@+id/layoutTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnPickFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_day_pill_selected"
                android:text="Pick Library File"
                android:textColor="@color/cm_on_primary"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvSelectedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No file selected"
                android:textColor="@color/cm_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Drive link field (Drive Mode) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDrive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="External Link"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:boxStrokeColor="@color/cm_primary"
            app:hintTextColor="@color/cm_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDriveUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:inputType="textUri"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/cm_primary"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_primary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Upload button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_day_pill_selected"
            android:text="Upload to Library"
            android:textColor="@color/cm_on_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </LinearLayout>

</ScrollView>
