<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_library_row"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_library_file_icon_blue">

        <ImageView
            android:id="@+id/ivFileIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_pdf"
            app:tint="@color/cm_on_primary" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:maxLines="1"
                android:textColor="@color/cm_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Midterm Study Guide" />

            <TextView
                android:id="@+id/tvFileBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_library_badge_red"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1.5dp"
                android:textColor="@color/cm_on_primary"
                android:textSize="8.5sp"
                android:textStyle="bold"
                tools:text="PDF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/cm_text_secondary"
            android:textSize="12sp"
            tools:text="Computer Networks" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_download_outline"
                app:tint="@color/cm_success" />

            <TextView
                android:id="@+id/tvOfflineSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/cm_success"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="2.4 MB (Offline)" />

            <TextView
                android:id="@+id/tvFileMeta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cm_text_muted"
                android:textSize="11sp"
                tools:text="• Saved 2 days ago" />
        </LinearLayout>
    </LinearLayout>

    <!-- Delete Cache Action Icon -->
    <ImageView
        android:id="@+id/btnDeleteCache"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="6dp"
        android:src="@drawable/ic_delete"
        app:tint="@color/cm_cancel_red" />

</LinearLayout>
