<?xml version="1.0" encoding="utf-8"?>
<!-- C:/Users/USER/AndroidStudioProjects/ClassMate/app/src/main/res/layout/activity_main.xml -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <com.shuaib.classmate.ui.StarfieldView
        android:id="@+id/starfield"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/mainViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden NavHostFragment to keep Navigation Component and DeepLinks working -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/nav_graph" />

    <com.shuaib.classmate.ui.GlassBottomNavView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_marginStart="@dimen/bottom_nav_horizontal_margin"
        android:layout_marginEnd="@dimen/bottom_nav_horizontal_margin"
        android:layout_marginBottom="@dimen/bottom_nav_bottom_margin"
        android:background="@drawable/bg_bottom_nav_glass"
        android:clipToOutline="true"
        android:paddingStart="@dimen/bottom_nav_inner_horizontal_padding"
        android:paddingEnd="@dimen/bottom_nav_inner_horizontal_padding"
        app:elevation="5dp"
        app:itemActiveIndicatorStyle="@style/App.CustomIndicator"
        app:itemBackground="@drawable/bg_bottom_nav_item_ripple"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconSize="23dp"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemPaddingBottom="10dp"
        app:itemPaddingTop="12dp"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/App.BottomNavLabel.Active"
        app:itemTextAppearanceInactive="@style/App.BottomNavLabel.Inactive"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabGlobalAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/cm_primary"
        app:elevation="6dp"
        app:hoveredFocusedTranslationZ="2dp"
        app:pressedTranslationZ="4dp"
        app:tint="@color/cm_on_primary"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
