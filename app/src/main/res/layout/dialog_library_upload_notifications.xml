<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_library_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="16dp"
    android:paddingEnd="18dp"
    android:paddingBottom="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Notifications"
        android:textColor="@color/cm_on_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUploadNotificationMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Recent PDF and file uploads"
        android:textColor="@color/cm_text_secondary"
        android:textSize="12sp" />

    <ProgressBar
        android:id="@+id/progressNotifications"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="22dp"
        android:indeterminateTint="#4D7CFE" />

    <TextView
        android:id="@+id/tvEmptyNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_library_row"
        android:gravity="center"
        android:padding="16dp"
        android:text="No upload notifications yet."
        android:textColor="@color/cm_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/uploadNotificationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        tools:visibility="visible" />
</LinearLayout>
