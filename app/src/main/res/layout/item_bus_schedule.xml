<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:clipToOutline="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/cm_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/cm_border_glass"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingEnd="16dp">

        <!-- Status Indicator Pill -->
        <FrameLayout
            android:layout_width="10dp"
            android:layout_height="match_parent">
            <View
                android:id="@+id/vStatusIndicator"
                android:layout_width="3.5dp"
                android:layout_height="42dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_badge_pill"
                android:backgroundTint="@color/cm_primary" />
        </FrameLayout>

        <!-- Icon Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutIconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <FrameLayout
                android:id="@+id/layoutIconBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_period_icon_tile">
                <ImageView
                    android:id="@+id/ivBusIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bus"
                    app:tint="@color/cm_primary" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Time & Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBusName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Double Decker Bus" />

            <TextView
                android:id="@+id/tvRoute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/cm_text_secondary"
                android:textSize="12sp"
                tools:text="Via Town Hall, Bypass" />

        </LinearLayout>

        <!-- Departure Time & Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDepartureTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="08:30 AM" />

            <TextView
                android:id="@+id/tvDirectionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2.5dp"
                android:textColor="@color/cm_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                tools:text="FROM CAMPUS" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
