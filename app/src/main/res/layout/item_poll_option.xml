<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/optionRoot"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_poll_option"
    android:clickable="true"
    android:focusable="true">

    <ProgressBar
        android:id="@+id/optionProgress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:progressDrawable="@drawable/bg_poll_progress"
        android:max="100"
        android:progress="0"
        android:visibility="visible"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            android:layout_marginEnd="10dp"
            android:visibility="gone"
            app:tint="@color/cm_primary" />

        <TextView
            android:id="@+id/tvOptionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/cm_text_primary"
            android:textSize="14.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOptionPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            tools:text="45%"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvOptionVotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/cm_text_muted"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
