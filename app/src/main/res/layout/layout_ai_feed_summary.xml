<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardAiSummary"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_ai_summary_card"
    android:orientation="vertical"
    android:padding="14dp"
    android:visibility="gone"
    tools:visibility="visible">

    <!-- Header Row (Always Visible) -->
    <LinearLayout
        android:id="@+id/layoutAiHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivAiSparkle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="AI Icon"
            android:src="@drawable/ic_ai_logo" />

        <TextView
            android:id="@+id/tvAiTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Today's AI Summary"
            android:textColor="@color/cm_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnAiActionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Expand"
            android:textColor="@color/cm_notice_resource"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivAiChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="Toggle Summary"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/cm_text_muted" />

        <ImageView
            android:id="@+id/btnAiDismiss"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:contentDescription="Dismiss Summary"
            android:src="@drawable/ic_close"
            app:tint="@color/cm_text_muted" />

    </LinearLayout>

    <!-- Content Block (Collapsible) -->
    <LinearLayout
        android:id="@+id/layoutAiContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Divider -->
        <View
            android:id="@+id/vAiDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/cm_divider" />

        <!-- Summary text -->
        <TextView
            android:id="@+id/tvAiSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/cm_text_secondary"
            android:textSize="13sp"
            android:autoLink="web"
            android:linksClickable="true"
            tools:text="- Structured programming class has been postponed to 11:30 AM today.\n- Physics Lab report submission deadline is next Tuesday.\n- ⚠️ ACTION REQUIRED: Register for the programming contest by 8:00 PM." />

        <!-- Loading State -->
        <LinearLayout
            android:id="@+id/layoutAiLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:indeterminateTint="@color/cm_notice_resource" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Analyzing today's updates..."
                android:textColor="@color/cm_text_muted"
                android:textSize="12.5sp"
                android:textStyle="italic" />

        </LinearLayout>

        <!-- Error / Offline State -->
        <LinearLayout
            android:id="@+id/layoutAiError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAiErrorMsg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Failed to generate summary."
                android:textColor="@color/cm_error"
                android:textSize="12.5sp" />

            <TextView
                android:id="@+id/btnAiRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Retry"
                android:textColor="@color/cm_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvAiFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:text="ClassMate AI"
            android:textColor="@color/cm_text_disabled"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>
