<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_bg">

    <com.shuaib.classmate.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.04" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_library_icon_button">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/back"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/cm_text_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Question Bank"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQbMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Past exam &amp; CT questions"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Upload button (admin only) -->
            <TextView
                android:id="@+id/btnUploadQuestion"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_library_upload_button"
                android:drawableStart="@drawable/ic_upload_arrow"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingStart="9dp"
                android:paddingEnd="11dp"
                android:text="Upload"
                android:textColor="@color/cm_primary"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:drawableTint="@color/cm_primary"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Filter row 1: Exam Type chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chipContainerExamType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingVertical="6dp" />
        </HorizontalScrollView>

        <!-- Filter row 2: Year chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chipContainerYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingVertical="4dp" />
        </HorizontalScrollView>

        <!-- Filter row 3: Course code chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chipContainerCourse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingVertical="4dp" />
        </HorizontalScrollView>

        <!-- List -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvQuestions"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="8dp"
                    android:paddingBottom="24dp"
                    tools:listitem="@layout/item_question_paper" />

                <LinearLayout
                    android:id="@+id/layoutEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:alpha="0.35"
                        android:src="@drawable/ic_result"
                        app:tint="@color/cm_text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="No question papers yet.\nBe the first to upload one!"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <!-- Shimmer -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp"
        android:visibility="gone"
        app:shimmer_auto_start="true"
        app:shimmer_base_alpha="0.4"
        app:shimmer_duration="1000"
        app:shimmer_highlight_alpha="0.8"
        app:shimmer_intensity="0.15">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <include layout="@layout/shimmer_item_pdf" />
            <include layout="@layout/shimmer_item_pdf" />
            <include layout="@layout/shimmer_item_pdf" />
            <include layout="@layout/shimmer_item_pdf" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

</FrameLayout>
