<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <com.shuaib.classmate.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="AI Settings"
            app:titleTextColor="@color/cm_text_primary"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/cm_text_primary" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/cm_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cm_border">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Section 1: Provider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ROUTING CONFIGURATION"
                            android:textColor="@color/cm_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_ai_logo"
                                app:tint="@color/cm_primary"
                                android:layout_marginEnd="12dp"/>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Primary Provider"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerPrimaryProvider"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:spinnerMode="dropdown"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Choose the main AI engine. If it fails or is rate-limited, the other engine will automatically serve as fallback."
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginStart="34dp"
                            android:layout_marginBottom="16dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/cm_border"
                            android:layout_marginBottom="16dp"/>

                        <!-- Section 2: Gemini -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GEMINI ENGINE CONFIGURATION"
                            android:textColor="@color/cm_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_ai_logo"
                                app:tint="@color/cm_primary"
                                android:layout_marginEnd="12dp"/>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Gemini Model"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerGeminiModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:spinnerMode="dropdown"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Select the Gemini model variant. Defaults to gemini-2.5-flash."
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginStart="34dp"
                            android:layout_marginBottom="16dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/cm_border"
                            android:layout_marginBottom="16dp"/>

                        <!-- Section 3: Groq -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GROQ ENGINE CONFIGURATION"
                            android:textColor="@color/cm_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_ai_logo"
                                app:tint="@color/cm_primary"
                                android:layout_marginEnd="12dp"/>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Groq Model"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/spinnerGroqModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:spinnerMode="dropdown"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Select the Groq model variant. Defaults to llama-3.3-70b-versatile."
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp"
                            android:layout_marginStart="34dp"
                            android:layout_marginBottom="4dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</FrameLayout>
