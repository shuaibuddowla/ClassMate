<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="16dp"
    android:paddingVertical="8dp">

    <!-- AI Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/ivAiAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_ai_logo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Message Content Container (No background/borders) -->
        <LinearLayout
            android:id="@+id/llContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Backup TextView for properties or simple binding -->
            <TextView
                android:id="@+id/tvMessageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="@color/cm_text_primary"
                android:textSize="15sp"
                android:lineSpacingExtra="2.5sp"
                android:textIsSelectable="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="2dp"
            android:textColor="@color/cm_text_secondary"
            android:textSize="10sp" />

        <!-- Actions Bar -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Copy Text"
                android:src="@drawable/ic_copy"
                app:tint="@color/cm_text_secondary"
                android:padding="6dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Share Text"
                android:src="@drawable/ic_share_outline"
                app:tint="@color/cm_text_secondary"
                android:padding="6dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnSpeak"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Speak Text"
                android:src="@drawable/ic_volume"
                app:tint="@color/cm_text_secondary"
                android:padding="6dp"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
