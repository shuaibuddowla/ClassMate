<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <com.shuaib.classmate.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_icon_container"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Start Attendance"
                android:textColor="@color/cm_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvClassId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cm_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutSubject"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="Subject"
                app:boxStrokeColor="@color/cm_primary"
                app:hintTextColor="@color/cm_primary">

                <AutoCompleteTextView
                    android:id="@+id/dropdownSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/cm_text_primary"
                    android:textColorHint="@color/cm_text_secondary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Attendance is currently enabled for this course only"
                android:textColor="@color/cm_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvSessionState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:padding="18dp"
                android:text="No active attendance session"
                android:textColor="@color/cm_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPresentCounter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_primary"
                android:gravity="center"
                android:padding="22dp"
                android:text="0 / 0 students marked present"
                android:textColor="@color/cm_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStartSession"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_gradient_button"
                android:text="Start Session"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEndSession"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/cm_cancel_red"
                android:enabled="false"
                android:text="End Session"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
