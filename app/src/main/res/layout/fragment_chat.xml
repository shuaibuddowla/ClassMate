<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_list_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Toolbar -->
        <LinearLayout
            android:id="@+id/aiChatHeader"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Go Back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/cm_text_primary"
                android:padding="10dp"
                android:scaleType="fitCenter" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="AI Icon"
                android:src="@drawable/ic_ai_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ClassMate AI"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Academic Assistant"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnClearChat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear Chat History"
                android:src="@drawable/ic_delete"
                app:tint="@color/cm_text_primary"
                android:padding="10dp"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- Header Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/cm_divider" />


        <!-- Message List Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Chat Messages list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAiChat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:scrollbars="vertical" />

            <!-- Redesigned Empty state dashboard when no message -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:visibility="gone">

                <!-- Welcome Header -->
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_ai_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to ClassMate AI"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Your elite academic representative and assistant. How can I help you today?"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp" />

                <!-- Rich suggestion cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card 1: Today's Classes -->
                    <LinearLayout
                        android:id="@+id/cardClasses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_icon_container"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_timetable"
                                app:tint="@color/cm_on_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅 Today's Classes"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View your scheduled periods, timings, and teachers."
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card 2: Summarize Notices -->
                    <LinearLayout
                        android:id="@+id/cardNotices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_icon_container"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_notice"
                                app:tint="@color/cm_on_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📢 Summarize Notices"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Get a quick summary of recent announcements and alerts."
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card 3: PDF Study Files -->
                    <LinearLayout
                        android:id="@+id/cardResources"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_icon_container"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_library_outline"
                                app:tint="@color/cm_on_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📖 PDF Study Files"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Browse and download syllabus, notes, and resource PDFs."
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card 4: Class Cancellations -->
                    <LinearLayout
                        android:id="@+id/cardCancellations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_icon_container"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_close"
                                app:tint="@color/cm_on_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚫 Class Cancellations"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Check if any classes are cancelled or rescheduled today."
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Typing Indicator (glowing thinking dots) -->
        <LinearLayout
            android:id="@+id/layoutTypingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="64dp"
            android:paddingVertical="6dp"
            android:gravity="start"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- AI Avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_ai_logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_bubble_received_modern"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:gravity="center_vertical">

                <com.facebook.shimmer.ShimmerFrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:shimmer_auto_start="true"
                    app:shimmer_duration="1200">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ClassMate AI is thinking"
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                        <TextView
                            android:id="@+id/tvThinkingDots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textColor="@color/cm_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="2dp" />
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Prompts / Suggestions Chips (relocated to bottom) -->
        <HorizontalScrollView
            android:id="@+id/scrollSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipClasses"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="📅 Today's Classes"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipNotices"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="📢 Summarize Notices"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipResources"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="📖 PDF Study Files"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chipCancellations"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="🚫 Any Cancellations?"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Bottom Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/cm_card"
            android:elevation="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <!-- Mic voice input Button -->
            <ImageButton
                android:id="@+id/btnVoiceInput"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voice Input"
                android:src="@drawable/ic_mic"
                app:tint="@color/cm_text_secondary"
                android:padding="8dp"
                android:scaleType="fitCenter" />

            <!-- Input edit text -->
            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_chat_input_modern"
                android:hint="Ask me anything about study..."
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:minHeight="40dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textColor="@color/cm_text_primary"
                android:textColorHint="@color/cm_text_secondary"
                android:textSize="15sp" />

            <!-- Send button -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chat_fab_gradient"
                android:contentDescription="Send Message"
                android:src="@drawable/ic_send"
                app:tint="@color/cm_on_primary"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:elevation="2dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
