<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_list_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <LinearLayout
            android:id="@+id/mainChatToolbar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_classmate_logo_mark" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ClassMate"
                android:textColor="@color/cm_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Search"
                android:src="@drawable/ic_search_modern"
                android:tint="@color/cm_text_primary" />

            <ImageButton
                android:id="@+id/btnCompose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Compose"
                android:src="@drawable/ic_edit"
                android:tint="@color/cm_text_primary" />
        </LinearLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_chat_chip_selected_blue"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="All"
                    android:textColor="@color/cm_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipGroups"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Groups"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chipDMs"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="DMs"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chipUnread"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="Unread"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/chatSearchBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etSearchChats"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chat_input_modern"
                android:drawableStart="@drawable/ic_search_modern"
                android:drawablePadding="10dp"
                android:hint="Search chats..."
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textColor="@color/cm_text_primary"
                android:textColorHint="@color/cm_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnCloseChatSearch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="X"
                android:textColor="@color/cm_text_secondary"
                android:textSize="18sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvChats"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="88dp" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <TextView
                android:id="@+id/tvEmptyChats"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="32dp"
                android:text="No chats found"
                android:textColor="@color/cm_text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="New Message"
        android:src="@drawable/ic_edit"
        app:backgroundTint="@color/cm_primary"
        app:borderWidth="0dp"
        app:elevation="6dp"
        app:fabSize="normal"
        app:srcCompat="@drawable/ic_edit"
        app:tint="@color/cm_on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
