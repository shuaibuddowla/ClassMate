<?xml version="1.0" encoding="utf-8"?>
<!-- C:/Users/USER/AndroidStudioProjects/ClassMate/app/src/main/res/layout/item_friend.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_primary"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/ivFriendProfile"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_default_avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFriendId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_day_pill_selected"
            android:padding="8dp"
            android:src="@drawable/ic_phone"
            app:tint="@color/cm_on_primary"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/btnWhatsapp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_badge_purple"
            android:padding="8dp"
            android:src="@drawable/ic_message"
            app:tint="@color/cm_on_primary" />

    </LinearLayout>

</LinearLayout>
