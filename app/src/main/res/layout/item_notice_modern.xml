<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/cm_surface_glass"
        app:cardCornerRadius="24dp"
        app:cardElevation="1dp"
        app:cardMaxElevation="3dp"
        app:cardPreventCornerOverlap="false"
        app:contentPadding="0dp"
        app:rippleColor="@color/cm_primary_container"
        app:strokeColor="@color/bottom_nav_stroke"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp">

                <!-- Sleek Top Header Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp">

                    <TextView
                        android:id="@+id/tvTypeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"
                        android:textColor="@color/cm_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:text="ASSIGNMENT" />

                    <TextView
                        android:id="@+id/tvBullet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="•"
                        android:textColor="@color/cm_text_muted"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/tvTypeLabel"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvSubject"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:textColor="@color/cm_text_muted"
                        android:textSize="10sp"
                        app:layout_constrainedWidth="true"
                        app:layout_constraintStart_toEndOf="@id/tvBullet"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:text="Digital Electronics and Pulse Techniques" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="4"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="16.5sp"
                    android:textStyle="bold"
                    tools:text="Assignment 3 submission guidelines" />

                <!-- Image Preview -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="10dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/RoundedCornersImage"
                    tools:src="@drawable/bg_notice_modern_card"
                    tools:visibility="visible" />

                <!-- Body text description -->
                <TextView
                    android:id="@+id/tvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp"
                    android:lineSpacingMultiplier="1.05"
                    android:maxLines="6"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13.5sp"
                    tools:text="Please read the attached PDF before Friday. Late submissions follow the course policy…" />

                <!-- Tags / Badges Row (Left Aligned Chips) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:gravity="center"
                        android:letterSpacing="0.03"
                        android:paddingHorizontal="9dp"
                        android:textAllCaps="false"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="10.5sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:background="@drawable/bg_notice_badge"
                        tools:text="3 days left"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/btnCardAiSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_notice_badge"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="9dp">

                        <TextView
                            android:id="@+id/tvCardAiSummaryAction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.03"
                            android:textColor="@color/cm_primary"
                            android:textSize="10.5sp"
                            android:textStyle="bold"
                            tools:text="AI Summary" />

                        <ProgressBar
                            android:id="@+id/pbCardAiSummary"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="4dp"
                            android:indeterminateTint="@color/cm_primary"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </LinearLayout>
                </LinearLayout>

                <!-- AI Summary Text container (collapsible) -->
                <LinearLayout
                    android:id="@+id/aiSummaryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_notice_elevated_card"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tvCardAiSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="13sp"
                        tools:text="Summary will appear here." />
                </LinearLayout>

                <!-- Very subtle divider between body and footer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/cm_border"
                    android:alpha="0.25" />

                <!-- Combined Footer Row (Timestamp left, Compact Actions right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMeta"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="11.5sp"
                        tools:text="May 12, 2026 · 02:30 PM" />

                    <!-- Compact actions cluster -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Like -->
                        <LinearLayout
                            android:id="@+id/btnLike"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="6dp">

                            <ImageView
                                android:id="@+id/ivLikeIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_heart_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvLikeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>

                        <!-- Comment -->
                        <LinearLayout
                            android:id="@+id/btnComment"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="6dp">

                            <ImageView
                                android:id="@+id/ivCommentIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_comment_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvCommentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>

                        <!-- Reminder -->
                        <LinearLayout
                            android:id="@+id/btnReminder"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="6dp">

                            <ImageView
                                android:id="@+id/ivReminderIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_bell_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />
                        </LinearLayout>

                        <!-- Share -->
                        <LinearLayout
                            android:id="@+id/btnForward"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="6dp">

                            <ImageView
                                android:id="@+id/ivShareIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_share_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvShareCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Floating pinning icon always stays in the top-right corner of the card -->
            <ImageView
                android:id="@+id/btnPin"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_notice_icon_circle"
                android:clickable="true"
                android:focusable="true"
                android:padding="7dp"
                android:rotation="30"
                android:scaleType="centerInside"
                android:src="@drawable/ic_pin_outline"
                app:tint="@color/cm_text_secondary"
                android:contentDescription="@string/notice_pin_cd"
                android:elevation="4dp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
