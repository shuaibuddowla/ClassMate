<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_notice_modern.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/cm_surface_glass"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardMaxElevation="4dp"
        app:cardPreventCornerOverlap="false"
        app:contentPadding="0dp"
        app:rippleColor="@color/cm_primary_container"
        app:strokeColor="@color/bottom_nav_stroke"
        app:strokeWidth="1.2dp">

        <!-- Content Area (FrameLayout holds content + floating pin/options) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp">

                <!-- Header Row: Subject Badge + Actions (AI, Pin, Options) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Subject Badge Container -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Subject Badge Capsule -->
                        <TextView
                            android:id="@+id/tvSubject"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_subject_pill"
                            android:textColor="@color/cm_primary"
                            android:textSize="11.5sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text="Physics II" />

                        <!-- Bullet (Hidden but preserved for backward compatibility) -->
                        <TextView
                            android:id="@+id/tvBullet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="•"
                            android:textColor="@color/cm_text_muted"
                            android:textSize="10.5sp"
                            android:visibility="gone"
                            tools:text="•" />
                    </LinearLayout>

                    <!-- AI Summary Pill -->
                    <LinearLayout
                        android:id="@+id/btnCardAiSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_notice_action_pill"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:id="@+id/tvCardAiSummaryAction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/cm_text_muted"
                            android:textSize="10.5sp"
                            android:textStyle="bold"
                            tools:text="✨ AI" />

                        <ProgressBar
                            android:id="@+id/pbCardAiSummary"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="4dp"
                            android:indeterminateTint="@color/cm_primary"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Floating pinning icon in the header row -->
                    <ImageView
                        android:id="@+id/btnPin"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_notice_icon_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="6dp"
                        android:rotation="30"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_pin_outline"
                        app:tint="@color/cm_text_secondary"
                        android:contentDescription="@string/notice_pin_cd" />

                    <!-- Floating options icon for admins in the header row -->
                    <ImageView
                        android:id="@+id/btnOptions"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_notice_icon_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="5dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_more_vert"
                        app:tint="@color/cm_text_secondary"
                        android:contentDescription="Notice options"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <!-- Tag & Priority Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Type Label Pill (Hidden but preserved for backward compatibility) -->
                    <TextView
                        android:id="@+id/tvTypeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:background="@drawable/bg_notice_badge"
                        android:gravity="center"
                        android:letterSpacing="0.04"
                        android:paddingHorizontal="10dp"
                        android:textAllCaps="true"
                        android:textColor="@color/cm_primary"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="ASSIGNMENT" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!-- Countdown Priority Chip -->
                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:gravity="center"
                        android:letterSpacing="0.03"
                        android:paddingHorizontal="10dp"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="3 days left"
                        tools:visibility="visible" />
                </LinearLayout>

                <!-- Notice Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Assignment 3 submission guidelines &amp; rubrics" />

                <!-- Image Preview Container (Optional) -->
                <FrameLayout
                    android:id="@+id/imagePreviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPreview"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/RoundedCornersImage"
                        tools:src="@drawable/bg_notice_modern_card" />

                    <!-- "Tap to view" badge overlay (bottom-end corner) -->
                    <TextView
                        android:id="@+id/tvTapToView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:background="#BB000000"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="🔍 Tap to view"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:clickable="false"
                        android:focusable="false" />

                </FrameLayout>


                <!-- Description / Body Text -->
                <TextView
                    android:id="@+id/tvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:lineSpacingMultiplier="1.1"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13.5sp"
                    android:autoLink="web"
                    android:linksClickable="true"
                    tools:text="Please read the attached PDF before Friday. Late submissions will follow the standard course policy. Ensure your team names are clearly stated on page 1 of the report." />

                <!-- Premium File Attachment Card (For PDFs/Docs) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/fileAttachmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/cm_surface_glass"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cm_divider"
                    app:strokeWidth="1dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="10dp">

                        <FrameLayout
                            android:id="@+id/fileIconContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_library_file_icon_red">

                            <TextView
                                android:id="@+id/tvFileExtension"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="@color/cm_on_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                tools:text="PDF" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFileName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="middle"
                                android:singleLine="true"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="12.5sp"
                                android:textStyle="bold"
                                tools:text="Syllabus_Fall_2026.pdf" />

                            <TextView
                                android:id="@+id/tvFileSize"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="10.5sp"
                                tools:text="Tap to open attachment" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btnOpenFile"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_open_external"
                            app:tint="@color/cm_primary"
                            android:padding="6dp"
                            android:contentDescription="Open file" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AI Summary Text container (collapsible) -->
                <LinearLayout
                    android:id="@+id/aiSummaryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_notice_elevated_card"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tvCardAiSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="12.5sp"
                        android:autoLink="web"
                        android:linksClickable="true"
                        tools:text="Summary will appear here." />
                </LinearLayout>

                <!-- Subtle divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/cm_divider"
                    android:alpha="0.25" />

                <!-- Combined Footer Row: Author details + Action Pills -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Left side: Author Details Block -->
                    <LinearLayout
                        android:id="@+id/layoutAuthorFooter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Author Avatar -->
                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="8dp">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/ivAuthorAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_default_avatar" />

                            <TextView
                                android:id="@+id/tvAuthorAvatarLetter"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:textColor="@color/cm_text_inverse"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                tools:visibility="visible"
                                tools:text="S" />
                        </FrameLayout>

                        <!-- Vertically stacked Author Name & Timestamp -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAuthorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="Dr. Sarah Rahman" />

                            <TextView
                                android:id="@+id/tvMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:textColor="@color/cm_text_disabled"
                                android:textSize="10sp"
                                tools:text="May 12, 2:30 PM" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Right side: Action Pills Cluster -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Like Pill -->
                        <LinearLayout
                            android:id="@+id/btnLike"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_notice_action_pill"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="6dp">

                            <ImageView
                                android:id="@+id/ivLikeIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_heart_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvLikeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:text="4" />
                        </LinearLayout>

                        <!-- Comment Pill -->
                        <LinearLayout
                            android:id="@+id/btnComment"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_notice_action_pill"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="6dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/ivCommentIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_comment_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvCommentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:text="2" />
                        </LinearLayout>



                        <!-- Reminder Pill -->
                        <LinearLayout
                            android:id="@+id/btnReminder"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_notice_action_pill"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:layout_marginEnd="6dp">

                            <ImageView
                                android:id="@+id/ivReminderIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_bell_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />
                        </LinearLayout>

                        <!-- Share Pill -->
                        <LinearLayout
                            android:id="@+id/btnForward"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_notice_action_pill"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/ivShareIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_share_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvShareCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:text="1" />
                        </LinearLayout>

                        <!-- Read Receipts Pill (Admin Only) -->
                        <LinearLayout
                            android:id="@+id/btnReadReceipts"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_notice_action_pill"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <ImageView
                                android:id="@+id/ivReadIcon"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_eye_outline"
                                app:tint="@color/cm_text_muted"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvReadCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:textColor="@color/cm_text_muted"
                                android:textSize="10.5sp"
                                android:textStyle="bold"
                                tools:text="0" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
