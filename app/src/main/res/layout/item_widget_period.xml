<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutWidgetPeriodRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:paddingHorizontal="10dp"
    android:layout_marginVertical="3dp">

    <!-- Status Indicator Pill -->
    <View
        android:id="@+id/vWidgetPeriodIndicator"
        android:layout_width="3.5dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_badge_pill"
        android:layout_marginEnd="10dp" />

    <!-- Details Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWidgetPeriodSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvWidgetPeriodMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2.5dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Time & Badge Section -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvWidgetPeriodTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWidgetPeriodBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1.5dp"
            android:textColor="@color/cm_primary"
            android:textSize="8.5sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</LinearLayout>
