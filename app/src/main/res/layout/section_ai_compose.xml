<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ CLASSMATE AI COMPOSER"
        android:textColor="@color/cm_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Paste messy draft details, dates, cancelled slots, or rough admin scribble. ClassMate AI will automatically structure, format, and prepare the notice fields for you."
        android:textColor="@color/cm_text_secondary"
        android:textSize="12.5sp"
        android:layout_marginBottom="16dp"
        android:lineSpacingMultiplier="1.15" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste messy draft details..."
        android:textColorHint="@color/cm_text_secondary"
        app:boxStrokeColor="@color/cm_primary"
        app:hintTextColor="@color/cm_primary"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAiMessyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="5"
            android:gravity="top"
            android:inputType="textMultiLine|textCapSentences"
            android:scrollbars="vertical"
            android:textColor="@color/cm_text_primary"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAiAnalyze"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Draft with AI"
        android:textAllCaps="false"
        android:textColor="@color/cm_on_primary"
        app:backgroundTint="@null"
        android:background="@drawable/bg_circle_accent"
        android:layout_marginBottom="16dp" />

    <!-- AI Detection Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_primary"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 AI DETECTION METRICS"
            android:textColor="@color/cm_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAiDetected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No draft analyzed yet."
            android:textColor="@color/cm_text_primary"
            android:textSize="13.5sp"
            android:lineSpacingMultiplier="1.2" />
    </LinearLayout>

</LinearLayout>
