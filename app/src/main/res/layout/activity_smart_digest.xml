<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER with gradient background -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_digest_header"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="36dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Smart Digest ✨"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnBack" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle"
                    tools:text="Tuesday, July 1, 2026" />

                <!-- Quick Stats row -->
                <LinearLayout
                    android:id="@+id/layoutQuickStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDate">

                    <TextView
                        android:id="@+id/tvStatClasses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        tools:text="0 classes" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="14dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="#66FFFFFF" />

                    <TextView
                        android:id="@+id/tvStatDeadlines"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        tools:text="0 deadlines" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="14dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="#66FFFFFF" />

                    <TextView
                        android:id="@+id/tvStatNotices"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        tools:text="0 notices" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- COUNTDOWN TO NEXT CLASS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/cm_card">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvCountdownLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Class"
                        android:textColor="@color/cm_text_muted"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvCountdownSubject"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/tvCountdownTime"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvCountdownLabel"
                        tools:text="Structured Programming" />

                    <TextView
                        android:id="@+id/tvCountdownTeacher"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/tvCountdownTime"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvCountdownSubject"
                        tools:text="CSE Department Teacher" />

                    <TextView
                        android:id="@+id/tvCountdownTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/cm_primary"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="1h 23m" />

                    <TextView
                        android:id="@+id/tvCountdownTimeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="remaining"
                        android:textColor="@color/cm_text_muted"
                        android:textSize="11sp"
                        app:layout_constraintEnd_toEndOf="@id/tvCountdownTime"
                        app:layout_constraintTop_toBottomOf="@id/tvCountdownTime" />

                    <TextView
                        android:id="@+id/tvNoMoreClasses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No more classes today 🎉"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI MORNING BRIEFING -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAiBriefing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/cm_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvAiBriefingTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="AI Morning Briefing"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAiBriefingContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="Good morning! You have a relatively light schedule today starting at 9:30 AM with structured programming. Don't forget your assignment due tonight." />

                    <!-- Shimmer placeholder for loading -->
                    <LinearLayout
                        android:id="@+id/shimmerAiBriefing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:layout_marginBottom="8dp"
                            android:background="@color/cm_border" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:layout_marginBottom="8dp"
                            android:background="@color/cm_border" />

                        <View
                            android:layout_width="200dp"
                            android:layout_height="14dp"
                            android:background="@color/cm_border" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAiBriefingError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textStyle="italic"
                        android:textColor="@color/cm_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="AI briefing unavailable." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TODAY'S SCHEDULE TIMELINE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="📋 Today's Schedule"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvNoClasses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="No classes scheduled for today"
                    android:textColor="@color/cm_text_muted"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- UPCOMING DEADLINES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDeadlinesHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="🔥 Upcoming Deadlines"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDeadlines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvNoDeadlines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="No upcoming deadlines — chill! 😎"
                    android:textColor="@color/cm_text_muted"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- STUDY SUGGESTIONS -->
            <LinearLayout
                android:id="@+id/layoutStudySuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="32dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="📚 Study Suggestions for Tomorrow"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStudySuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/tvNoSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="No study materials found for tomorrow's subjects"
                    android:textColor="@color/cm_text_muted"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
