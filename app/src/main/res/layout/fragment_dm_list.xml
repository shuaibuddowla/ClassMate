<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_list_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/cm_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Message"
            android:textColor="@color/cm_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <EditText
            android:id="@+id/etSearchUsers"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_chat_input_modern"
            android:drawableStart="@drawable/ic_search_modern"
            android:drawablePadding="10dp"
            android:hint="Search classmates..."
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/cm_text_primary"
            android:textColorHint="@color/cm_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_chat_chip_selected_blue"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="All"
                android:textColor="@color/cm_on_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipOnline"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chat_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Online"
                android:textColor="@color/cm_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipAdmins"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chat_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Admins"
                android:textColor="@color/cm_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipStudents"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chat_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Students"
                android:textColor="@color/cm_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="Contacts"
        android:textColor="@color/cm_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/tvEmptyUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:alpha="0.5"
            android:src="@drawable/ic_person"
            android:tint="@color/cm_primary" />

        <TextView
            android:id="@+id/tvEmptyUsersMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No classmates found"
            android:textColor="@color/cm_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
