<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="156dp"
    android:layout_height="164dp"
    android:layout_marginEnd="12dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_library_row"
    android:orientation="vertical"
    android:padding="13dp">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_library_file_icon_blue">

        <ImageView
            android:id="@+id/ivSubjectIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_timetable"
            app:tint="@color/cm_on_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvSubjectCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="11dp"
        android:textColor="@color/cm_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        tools:text="CSE1201" />

    <TextView
        android:id="@+id/tvSubjectName"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:maxLines="3"
        android:textColor="@color/cm_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="Electronic Devices and Circuits" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPdfCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/cm_text_secondary"
            android:textSize="12sp"
            tools:text="8 resources" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/cm_primary" />
    </LinearLayout>
</LinearLayout>
