<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="12dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_primary"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:minWidth="85dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="none"/>

            <View
                android:layout_width="2dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_left_accent"
                android:layout_gravity="center"
                android:layout_marginVertical="3dp"/>

            <TextView
                android:id="@+id/tvEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="none"/>

        </LinearLayout>

        <View
            android:layout_width="3dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_left_accent"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="2"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="12sp"
                app:autoSizeMaxTextSize="18sp"
                app:autoSizeStepGranularity="1sp"/>

            <TextView
                android:id="@+id/tvTeacher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvCancelledMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ This class has been cancelled"
                android:textColor="@color/cm_cancel_red"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvSubstituteMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textSize="10sp"
            android:textColor="@color/cm_primary"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
