<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_list_background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/cm_text_primary" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivToolbarAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_users"
                android:tint="@color/cm_on_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="CODRIX-22"
                android:textColor="@color/cm_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/viewConnectionDot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_status_dot" />

                <TextView
                    android:id="@+id/tvOnlineStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="24 members"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Search"
            android:src="@drawable/ic_search_modern"
            android:tint="@color/cm_text_secondary" />
    </LinearLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/toolbarProgress"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/cm_primary"
        app:layout_constraintTop_toBottomOf="@id/chatToolbar"
        app:trackColor="?android:attr/colorBackground" />

    <TextView
        android:id="@+id/tvConnectionBanner"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center"
        android:textColor="@color/cm_on_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbarProgress" />

    <LinearLayout
        android:id="@+id/pinnedBanner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/cm_surface_glass"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvConnectionBanner">

        <View
            android:layout_width="2dp"
            android:layout_height="24dp"
            android:background="@color/cm_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pinned Message"
                android:textColor="@color/cm_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPinnedMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cm_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnUnpin"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="X"
            android:textColor="@color/cm_text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/cm_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/etSearchMessages"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_modern"
            android:hint="Search messages..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/cm_text_primary"
            android:textColorHint="@color/cm_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnCloseSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="X"
            android:textColor="@color/cm_text_secondary"
            android:textSize="18sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/cm_background"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/swipeRefresh"
        app:layout_constraintTop_toBottomOf="@id/searchBar" />

    <!-- Message Area -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomComposeArea"
        app:layout_constraintTop_toBottomOf="@id/pinnedBanner">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomComposeArea"
        app:layout_constraintTop_toBottomOf="@id/chatToolbar">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:alpha="0.6"
            android:src="@drawable/ic_chat"
            android:tint="@color/cm_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No messages yet"
            android:textColor="@color/cm_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Start the conversation with the class group."
            android:textColor="@color/cm_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSayHello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#2563EB"
            android:text="Say hello 👋"
            android:textAllCaps="false"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <!-- Bottom Compose Area -->
    <LinearLayout
        android:id="@+id/bottomComposeArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:id="@+id/imageUploadOverlay"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:visibility="gone">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="true"
                app:indicatorColor="@color/cm_primary" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/replyEditBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/cm_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <View
                android:layout_width="2dp"
                android:layout_height="32dp"
                android:background="@color/cm_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvModeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cm_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvModeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnCancelMode"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="X"
                android:textColor="@color/cm_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTypingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="4dp"
            android:textColor="@color/cm_text_secondary"
            android:textSize="12sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/messageBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_chat_input_modern"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <ImageButton
                    android:id="@+id/btnAttach"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_attach"
                    android:tint="@color/cm_text_secondary" />

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Message..."
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="6"
                    android:minHeight="40dp"
                    android:paddingHorizontal="8dp"
                    android:textColor="@color/cm_text_primary"
                    android:textColorHint="@color/cm_text_secondary"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/btnEmoji"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_smile"
                    android:tint="@color/cm_text_secondary" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp">

                <ImageButton
                    android:id="@+id/btnMic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_chat_fab_gradient"
                    android:src="@drawable/ic_mic"
                    android:tint="@color/cm_on_primary" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_chat_fab_gradient"
                    android:src="@drawable/ic_send"
                    android:tint="@color/cm_on_primary"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
