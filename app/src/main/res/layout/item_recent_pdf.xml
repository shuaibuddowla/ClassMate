<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="136dp"
    android:layout_height="132dp"
    android:layout_marginVertical="4dp"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_library_card"
    android:padding="10dp">

    <!-- Top Row: Type Badge and Star -->
    <TextView
        android:id="@+id/tvFileBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_library_badge_red"
        android:paddingHorizontal="6dp"
        android:paddingVertical="1.5dp"
        android:textColor="@color/cm_file_pdf_text"
        android:textSize="8.5sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="PDF" />

    <ImageView
        android:id="@+id/btnFavorite"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="2dp"
        android:src="@drawable/ic_star_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/cm_text_secondary" />

    <!-- Middle: Icon and Lab Chip -->
    <LinearLayout
        android:id="@+id/iconLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFileBadge"
        app:layout_constraintVertical_bias="0.2">

        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_library_file_icon_red">

            <ImageView
                android:id="@+id/ivFileIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_file_pdf"
                app:tint="#FF6B7A" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvLabTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_library_badge_green"
            android:paddingHorizontal="5dp"
            android:paddingVertical="1.5dp"
            android:text="LAB"
            android:textColor="@color/cm_file_lab_text"
            android:textSize="7.5sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- Bottom Section: Title, Subject, Meta -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:maxLines="1"
        android:textColor="@color/cm_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tvSubject"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Midterm Notes" />

    <TextView
        android:id="@+id/tvSubject"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/cm_text_secondary"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@+id/metaContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Physics II" />

    <LinearLayout
        android:id="@+id/metaContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_person"
            app:tint="@color/cm_text_secondary" />

        <TextView
            android:id="@+id/tvFileMeta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/cm_text_secondary"
            android:textSize="9.5sp"
            tools:text="Yesterday - 2.4 MB" />
    </LinearLayout>

    <!-- Invisible Placeholders -->
    <ImageView android:id="@+id/btnDelete" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <TextView android:id="@+id/btnDownloadView" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <ProgressBar android:id="@+id/progressDownload" style="?android:attr/progressBarStyleHorizontal" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
