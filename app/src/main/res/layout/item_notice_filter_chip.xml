<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chipRoot"
    android:layout_width="wrap_content"
    android:layout_height="34dp"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_notice_chip"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp">

    <TextView
        android:id="@+id/tvChipIcon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_notice_icon_circle"
        android:gravity="center"
        android:text="i"
        android:textColor="@color/cm_primary_soft"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvChipLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_text_secondary"
            android:textSize="12.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChipCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/cm_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
