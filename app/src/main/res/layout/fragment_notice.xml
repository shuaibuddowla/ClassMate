<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 1. The RecyclerView feed (Placed first to be at the bottom of the Z-stack) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNotices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="14dp"
                android:paddingTop="128dp"
                android:paddingBottom="24dp"
                android:scrollbars="vertical"
                android:layoutAnimation="@anim/layout_animation_library_list"
                tools:listitem="@layout/item_notice_modern" />

            <!-- 2. Today's AI Summary Card (Floats above RecyclerView, but below Header) -->
            <include
                android:id="@+id/aiSummaryCard"
                layout="@layout/layout_ai_feed_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="72dp"
                android:layout_marginBottom="4dp"
                android:elevation="8dp" />

            <!-- 3. Today's Notices Reminder Banner -->
            <LinearLayout
                android:id="@+id/layoutReminderBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginStart="14dp"
                android:layout_marginTop="72dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_primary"
                android:elevation="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="8dp"
                    android:text="📋"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvReminderText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="10"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="You have 3 notices today" />

                <ImageButton
                    android:id="@+id/btnDismissReminder"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Dismiss"
                    android:src="@drawable/ic_close"
                    app:tint="@color/cm_text_secondary" />
            </LinearLayout>

            <!-- 4. Shimmer View (Should cover the feed, so it has paddingTop of 72dp to clear the header) -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="14dp"
                android:paddingTop="72dp"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.4"
                app:shimmer_duration="1000"
                app:shimmer_highlight_alpha="0.8"
                app:shimmer_intensity="0.15">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/shimmer_item_notice" />
                    <include layout="@layout/shimmer_item_notice" />
                    <include layout="@layout/shimmer_item_notice" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- 5. Empty State (Should also center under the header, let's give it a paddingTop of 72dp) -->
            <LinearLayout
                android:id="@+id/emptyNoticeState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="72dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_notice_elevated_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="22dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_notice_icon_circle">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_classmate_logo_mark" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvEmptyTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="No notices yet" />

                    <TextView
                        android:id="@+id/tvEmptySubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="14sp"
                        tools:text="Important class updates will appear here." />

                    <TextView
                        android:id="@+id/btnEmptyReset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:text="@string/notice_empty_reset"
                        android:textColor="@color/cm_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/btnEmptyPost"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_notice_action_pill"
                        android:backgroundTint="@color/cm_primary"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:text="Post First Notice"
                        android:textColor="@color/cm_on_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- 6. Pinned Floating Header (Placed last so it is Z-ordered at the very top of everything) -->
            <!-- Fully transparent background so content can be seen scrolling underneath it -->
            <LinearLayout
                android:id="@+id/noticeHeaderPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:background="@android:color/transparent"
                android:layout_gravity="top"
                android:elevation="9dp">

                <LinearLayout
                    android:id="@+id/appBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="44dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/headerTitleBlock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNoticeTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:text="@string/nav_notices"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNoticeSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp"
                            tools:text="12 updates · Pull to refresh" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/searchContainer"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_notice_search"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_search_modern"
                            app:tint="@color/cm_text_secondary" />

                        <EditText
                            android:id="@+id/etNoticeSearch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/hint_notice_search"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:singleLine="true"
                            android:textColor="@color/cm_text_primary"
                            android:textColorHint="@color/cm_text_secondary"
                            android:textSize="14sp" />

                        <ImageButton
                            android:id="@+id/btnCloseSearch"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/cancel"
                            android:src="@drawable/ic_close"
                            app:tint="@color/cm_text_secondary" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnSearch"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_library_icon_button"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/hint_notice_search"
                            android:src="@drawable/ic_search_modern"
                            app:tint="@color/cm_text_secondary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/btnPostNotice"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_notice_action_pill"
                        android:backgroundTint="@color/cm_primary"
                        android:gravity="center"
                        android:minWidth="76dp"
                        android:paddingHorizontal="14dp"
                        android:text="Post"
                        android:textColor="@color/cm_on_primary"
                        android:textSize="13.5sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</FrameLayout>
