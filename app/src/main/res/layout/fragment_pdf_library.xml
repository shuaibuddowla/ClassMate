<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_bg">


    <com.shuaib.classmate.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.04" />

    <!-- Fixed header: stays pinned while the library data scrolls underneath. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/titleColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/rightIconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvLibraryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="none"
                android:fontFamily="serif"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Library"
                android:textColor="@color/cm_text_primary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:lineSpacingExtra="1dp"
                android:text="Learn. Access. Achieve."
                android:textColor="@color/cm_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightIconContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="188dp">

            <FrameLayout
                android:id="@+id/btnLibrarySearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_library_icon_button">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="Search library"
                    android:src="@drawable/ic_search_modern"
                    app:tint="@color/cm_text_secondary" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnLibraryNotifications"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_library_icon_button">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/notifications"
                    android:src="@drawable/ic_bell_outline"
                    app:tint="@color/cm_text_secondary" />

                <View
                    android:id="@+id/libraryNotificationDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_library_notification_dot"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/btnUploadPdf"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_library_upload_button"
                android:drawableStart="@drawable/ic_upload_arrow"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingStart="9dp"
                android:paddingEnd="11dp"
                android:text="Upload"
                android:textColor="@color/cm_primary"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:drawableTint="@color/cm_primary"
                tools:visibility="visible" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="78dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="140dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <!-- TASK 3: FIX RECENTLY UPLOADED CARDS - Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:text="Recently Uploaded"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@drawable/ic_chevron_right"
                        android:drawablePadding="4dp"
                        android:gravity="center"
                        android:text="View all"
                        android:textColor="@color/cm_primary"
                        android:textSize="14sp"
                        app:drawableTint="@color/cm_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecentEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_library_card"
                    android:gravity="center"
                    android:padding="22dp"
                    android:text="No resources yet\nUploaded files will appear here."
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- TASK 3: RECENTLY UPLOADED RECYCLERVIEW -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingHorizontal="24dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_recent_pdf" />

                <!-- Offline Downloads Button -->
                <LinearLayout
                    android:id="@+id/btnOfflineDownloads"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="24dp"
                    android:background="@drawable/bg_library_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_library_file_icon_blue">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_download_outline"
                            app:tint="@color/cm_primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="Offline Downloads"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOfflineDownloadsMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0 files downloaded"
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/cm_primary" />
                </LinearLayout>

                <!-- Question Bank Banner -->
                <LinearLayout
                    android:id="@+id/btnQuestionBank"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="24dp"
                    android:background="@drawable/bg_library_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_library_file_icon_red">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_result"
                            app:tint="@color/cm_on_primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="Question Bank"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Past Finals, CTs &amp; Mid exam papers"
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/cm_cancel_red" />
                </LinearLayout>

                <!-- TASK 6: FIX COURSES SECTION - Header and Spacing -->
                <LinearLayout
                    android:id="@+id/coursesHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="Courses"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLibrarySummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 resources across 0 subjects"
                            android:textColor="@color/cm_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCollapseAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@drawable/ic_chevron_right"
                        android:drawablePadding="4dp"
                        android:text="Expand All"
                        android:textColor="@color/cm_primary"
                        android:textSize="14sp"
                        app:drawableTint="@color/cm_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNoSubjectResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_library_card"
                    android:gravity="center"
                    android:padding="18dp"
                    android:text="No files for this course yet"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- COURSE GROUPS CONTAINER -->
                <LinearLayout
                    android:id="@+id/courseGroupContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_library_group_container"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Regular Courses -->
                    <LinearLayout
                        android:id="@+id/headerRegular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="13dp"
                            android:background="@drawable/bg_library_file_icon_blue">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_library_outline"
                                app:tint="@color/cm_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="Regular Courses"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvRegularMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0 subjects - 0 resources"
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRegularCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_library_badge_blue"
                            android:minWidth="38dp"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="7dp"
                            android:text="0"
                            android:textColor="@color/cm_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivArrowRegular"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/cm_primary" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRegular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone"
                        tools:listitem="@layout/item_subject_card" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/cm_divider" />

                    <!-- Lab Courses -->
                    <LinearLayout
                        android:id="@+id/headerLab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="16dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="13dp"
                            android:background="@drawable/bg_library_file_icon_green">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_flask_outline"
                                app:tint="@color/cm_success" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="Lab Courses"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvLabMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0 subjects - 0 resources"
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvLabCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_library_badge_green"
                            android:gravity="center"
                            android:minWidth="38dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="7dp"
                            android:text="0"
                            android:textColor="@color/cm_success"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivArrowLab"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/cm_success" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone"
                        tools:listitem="@layout/item_subject_card" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/cm_divider" />

                    <!-- Other Materials -->
                    <LinearLayout
                        android:id="@+id/headerOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="16dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="13dp"
                            android:background="@drawable/bg_library_file_icon_purple">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_folder_outline"
                                app:tint="@color/cm_file_other_text" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="Other Materials"
                                android:textColor="@color/cm_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvOtherMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Notes, Assignments, Question Papers"
                                android:textColor="@color/cm_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvOtherCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_library_badge_purple"
                            android:gravity="center"
                            android:minWidth="38dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="7dp"
                            android:text="0"
                            android:textColor="@color/cm_file_other_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivArrowOther"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/cm_file_other_text" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone"
                        tools:listitem="@layout/item_subject_card" />
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="180dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Shimmer loading state -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:shimmer_auto_start="true"
            app:shimmer_base_alpha="0.4"
            app:shimmer_duration="1000"
            app:shimmer_highlight_alpha="0.8"
            app:shimmer_intensity="0.15">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">
                <!-- Shimmer title 1 -->
                <View
                    android:layout_width="160dp"
                    android:layout_height="18dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/cm_text_secondary"
                    android:alpha="0.2"/>
                <!-- Horizontal items -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp">
                    <include layout="@layout/item_shimmer_pdf" android:layout_width="280dp" android:layout_height="84dp" android:layout_marginEnd="12dp"/>
                    <include layout="@layout/item_shimmer_pdf" android:layout_width="280dp" android:layout_height="84dp"/>
                </LinearLayout>
                <!-- Shimmer title 2 -->
                <View
                    android:layout_width="120dp"
                    android:layout_height="18dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/cm_text_secondary"
                    android:alpha="0.2"/>
                <!-- List items -->
                <include layout="@layout/item_shimmer_pdf"/>
                <include layout="@layout/item_shimmer_pdf"/>
                <include layout="@layout/item_shimmer_pdf"/>
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>
    </FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</FrameLayout>
