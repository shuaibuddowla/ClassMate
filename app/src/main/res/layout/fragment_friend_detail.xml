<?xml version="1.0" encoding="utf-8"?>
<!-- C:/Users/USER/AndroidStudioProjects/ClassMate/app/src/main/res/layout/fragment_friend_detail.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivFriendDetailProfile"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_default_avatar" />

            <TextView
                android:id="@+id/tvFriendDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cm_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvFriendDetailRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_purple"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:textColor="@color/cm_accent"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_card"
            android:layout_marginHorizontal="16dp"
            android:padding="16dp">

            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendId"/>
            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendEmail"/>
            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendPhone"/>
            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendBlood"/>
            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendDistrict"/>
            <include layout="@layout/item_profile_detail" android:id="@+id/detailFriendAddress"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDetailCall"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Call"
                    app:icon="@drawable/ic_phone"
                    app:iconGravity="textStart"
                    android:backgroundTint="@color/cm_primary"
                    app:cornerRadius="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDetailWhatsapp"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="WhatsApp"
                    app:icon="@drawable/ic_message"
                    app:iconGravity="textStart"
                    android:backgroundTint="#25D366"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
