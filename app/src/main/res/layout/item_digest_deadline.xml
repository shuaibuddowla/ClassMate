<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardDeadline"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/cm_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/viewUrgencyDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_urgency_indicator"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDeadlineSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/cm_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/viewUrgencyDot"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="CSE1203" />

        <TextView
            android:id="@+id/tvDeadlineTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/cm_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvDeadlineCountdown"
            app:layout_constraintStart_toStartOf="@id/tvDeadlineSubject"
            app:layout_constraintTop_toBottomOf="@id/tvDeadlineSubject"
            tools:text="Assignment 2 Submission" />

        <TextView
            android:id="@+id/tvDeadlineBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/cm_text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/tvDeadlineCountdown"
            app:layout_constraintStart_toStartOf="@id/tvDeadlineSubject"
            app:layout_constraintTop_toBottomOf="@id/tvDeadlineTitle"
            tools:text="Submit Structured Programming Assignment 2 on Array and Pointer operations." />

        <TextView
            android:id="@+id/tvDeadlineCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cm_error"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2d left" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
