<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="16dp">

    <!-- Timeline left section -->
    <View
        android:id="@+id/viewTimelineDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_digest_timeline_dot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewTimelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_digest_timeline_line"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/viewTimelineDot"
        app:layout_constraintStart_toStartOf="@id/viewTimelineDot"
        app:layout_constraintTop_toBottomOf="@id/viewTimelineDot" />

    <!-- Timeline content section -->
    <TextView
        android:id="@+id/tvTimelineTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textColor="@color/cm_text_muted"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/viewTimelineDot"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="9:00 AM – 10:30 AM" />

    <TextView
        android:id="@+id/tvTimelineSubject"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/cm_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvCancelledBadge"
        app:layout_constraintStart_toStartOf="@id/tvTimelineTime"
        app:layout_constraintTop_toBottomOf="@id/tvTimelineTime"
        tools:text="Structured Programming" />

    <TextView
        android:id="@+id/tvTimelineTeacher"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textColor="@color/cm_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvTimelineTime"
        app:layout_constraintTop_toBottomOf="@id/tvTimelineSubject"
        tools:text="Hadifur Sir" />

    <TextView
        android:id="@+id/tvCancelledBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_urgency_indicator"
        android:backgroundTint="@color/cm_error"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="CANCELLED"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tvTimelineSubject"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTimelineSubject" />
</androidx.constraintlayout.widget.ConstraintLayout>
