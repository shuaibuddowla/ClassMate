<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_timetable.xml -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <!-- Header: current day name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTodayLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_label"
                    android:textColor="@color/cm_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>

                <TextView
                    android:id="@+id/tvSelectedDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Day selector pills (Sat–Fri) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/daySelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/calendarExceptionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_calendar_exception_banner"
            android:gravity="center_vertical"
            android:minHeight="128dp"
            android:orientation="horizontal"
            android:padding="18dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_calendar_outline_icon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="☾"
                    android:textColor="@color/cm_accent"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvExceptionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:autoSizeMaxTextSize="20sp"
                    app:autoSizeMinTextSize="15sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/tvExceptionDateRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvExceptionMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="52dp"
                android:layout_height="72dp"
                android:gravity="center"
                android:text="☾"
                android:textColor="@color/cm_warning"
                android:textSize="58sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/calendarExceptionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_calendar_status_strip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_blue"
                android:gravity="center"
                android:text="i"
                android:textColor="@color/cm_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExceptionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Timetable preserved - Vacation override active"
                android:textColor="@color/cm_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Period count badge -->
        <TextView
            android:id="@+id/tvPeriodCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="@color/cm_primary"
            android:textSize="12sp"/>

        <!-- Periods list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPeriods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingBottom="16dp"/>

