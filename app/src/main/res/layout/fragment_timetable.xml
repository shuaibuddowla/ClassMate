<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_timetable.xml -->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cm_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="104dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- GREETING HEADER                                     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:id="@+id/layoutGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btnWhatsApp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.01"
                        android:text="Hello,"
                        android:textColor="@color/cm_text_disabled"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif"
                            android:letterSpacing="-0.02"
                            android:maxLines="1"
                            android:text="Student"
                            android:textColor="@color/cm_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:text=" 👋"
                            android:textSize="24sp" />

                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnWhatsApp"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Open WhatsApp Group"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_whatsapp" />

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SMART DIGEST ENTRY CARD                              -->
            <!-- ═══════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSmartDigest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cm_primary_soft"
                app:cardBackgroundColor="@color/cm_card">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/bg_bottom_nav_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDigestIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_urgency_indicator"
                        android:backgroundTint="@color/cm_primary_soft"
                        android:padding="10dp"
                        android:src="@drawable/ic_digest"
                        app:tint="@color/cm_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvDigestTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="Daily Smart Digest ✨"
                        android:textColor="@color/cm_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivDigestIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tvDigestSub"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvDigestSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="2dp"
                        android:text="Your AI daily command center"
                        android:textColor="@color/cm_text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/ivDigestIcon"
                        app:layout_constraintTop_toBottomOf="@id/tvDigestTitle"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/cm_text_muted"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- DAY SELECTOR — Individual rounded-square cards      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="14dp"
                android:paddingBottom="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/daySelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ROUTINE / BUS TOGGLE                                -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutScheduleToggle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_toggle_container"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/btnToggleRoutine"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_item_selected"
                    android:gravity="center"
                    android:text="Class Routine"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnToggleBus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:text="Bus Schedule"
                    android:textColor="@color/cm_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- NEXT CLASS HERO CARD                                -->
            <!-- ═══════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroNextClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_next_class"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Top row: "NEXT CLASS" badge + countdown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvHeroBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_hero_badge"
                            android:letterSpacing="0.15"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:text="NEXT CLASS"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvHeroCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivHeroChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="0"
                            app:tint="#CCFFFFFF"
                            android:importantForAccessibility="no" />

                    </LinearLayout>

                    <!-- Subject name -->
                    <TextView
                        android:id="@+id/tvHeroSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Time + Teacher row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#AAFFFFFF"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvHeroTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="5dp"
                                android:src="@drawable/ic_person"
                                app:tint="#AAFFFFFF"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tvHeroTeacher"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Progress Bar for Class Start Time -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/pbHeroTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:indicatorColor="#FFFFFF"
                        app:trackColor="#40FFFFFF"
                        app:trackCornerRadius="4dp"
                        app:trackThickness="4dp"
                        android:progress="0"
                        android:visibility="gone" />

                    <!-- Collapsible Details Container -->
                    <LinearLayout
                        android:id="@+id/heroDetailsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#26FFFFFF" />

                        <!-- Quick Link to Class Notes button -->
                        <LinearLayout
                            android:id="@+id/btnHeroClassNotes"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_hero_action_pill"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_library_outline"
                                app:tint="#FFFFFF"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View Class Notes"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CALENDAR EXCEPTION BANNER                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calendarExceptionBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_vacation"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Circular Emoji Container on the Left -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_vacation_icon_container">

                        <TextView
                            android:id="@+id/tvExceptionEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🌴"
                            android:textSize="22sp" />
                    </FrameLayout>

                    <!-- Text Details on the Right -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Top row: Badge & Date Range -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:id="@+id/tvExceptionBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VACATION ACTIVE"
                                android:textColor="#CCFFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" • "
                                android:textColor="#99FFFFFF"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/tvExceptionDateRange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#E6FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Prominent Title -->
                        <TextView
                            android:id="@+id/tvExceptionTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp" />

                        <!-- Message Description -->
                        <TextView
                            android:id="@+id/tvExceptionMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="1dp"
                            android:textColor="#F2FFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SCHEDULE SECTION HEADER                             -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/scheduleHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvScheduleLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S SCHEDULE"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/cm_text_disabled"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvPeriodCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_blue"
                    android:fontFamily="sans-serif"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/cm_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SHIMMER LOADING PLACEHOLDER                         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.4"
                app:shimmer_duration="1000"
                app:shimmer_highlight_alpha="0.8"
                app:shimmer_intensity="0.15">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <include layout="@layout/item_shimmer_period" />
                    <include layout="@layout/item_shimmer_period" />
                    <include layout="@layout/item_shimmer_period" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- PERIODS LIST                                         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPeriods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingBottom="8dp"/>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ASSIGNMENT COUNTDOWNS SECTION                       -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/countdownSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 UPCOMING DEADLINES"
                    android:textColor="@color/cm_text_disabled"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCountdowns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- EMPTY STATE                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="300dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/emoji_party"
                    android:textSize="48sp"/>

                <TextView
                    android:id="@+id/tvNoClassesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_classes_title"
                    android:textColor="@color/cm_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvNoClassesSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enjoy_free_day"
                    android:textColor="@color/cm_text_muted"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
