<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base solid layer -->
    <item>
        <shape>
            <solid android:color="@color/cm_surface_glass" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Gradient overlay layer -->
    <item>
        <shape>
            <gradient
                android:startColor="#1F7C3AED"
                android:centerColor="#0F2563EB"
                android:endColor="#1FEC4899"
                android:angle="135" />
            <stroke
                android:width="1.5dp"
                android:color="#4D7C3AED" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
