<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_glass_card.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark glass background -->
    <item>
        <shape>
            <solid android:color="#B40D1526"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Top highlight (Fixed offset instead of percentage) -->
    <item android:bottom="40dp">
        <shape>
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"/>
            <corners
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp"/>
        </shape>
    </item>
    <!-- Border -->
    <item>
        <shape>
            <solid android:color="#00000000"/>
            <stroke
                android:width="1dp"
                android:color="#1EFFFFFF"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
