<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow shadow layer (Green) -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp"
        android:top="0dp">
        <shape>
            <solid android:color="#1A22C55E"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Main card background -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape>
            <solid android:color="@color/cm_card"/>
            <corners android:radius="24dp"/>
            <stroke
                android:width="2dp"
                android:color="@color/cm_success"/>
        </shape>
    </item>
</layer-list>