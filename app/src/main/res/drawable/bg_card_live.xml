<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_card_live.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft glow/shadow layer (Green) -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#1416A34A"/> <!-- 8% opacity green -->
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Base opaque card background -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="@color/cm_card"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Main card background tint overlay & stroke -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="2dp">
        <shape>
            <!-- 5% green background tint inside the card for active context recognition -->
            <solid android:color="#0D16A34A"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="1dp"
                android:color="#4016A34A"/> <!-- 25% opacity green -->
        </shape>
    </item>
</layer-list>