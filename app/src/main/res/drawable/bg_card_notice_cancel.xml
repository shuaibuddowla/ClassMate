<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_card_notice_cancel.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft glow/shadow layer (Red) -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#0DDC2626"/> <!-- 5% opacity red -->
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Base opaque card background -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="@color/cm_card"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Main card background tint overlay & stroke -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#0DDC2626"/> <!-- 5% red background tint -->
            <corners android:radius="20dp"/>
            <stroke
                android:width="1dp"
                android:color="#26DC2626"/> <!-- 15% opacity red -->
        </shape>
    </item>
</layer-list>
