<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_hero_next_class.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main gradient background with 70% opacity -->
    <item>
        <shape>
            <gradient
                android:startColor="#B31D4ED8"
                android:centerColor="#B32563EB"
                android:endColor="#B33B82F6"
                android:angle="135"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Subtle top highlight for depth -->
    <item android:bottom="60dp">
        <shape>
            <gradient
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"/>
            <corners
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Glassmorphic border -->
    <item>
        <shape>
            <stroke android:width="1dp" android:color="@color/bottom_nav_stroke" />
            <corners android:radius="24dp"/>
        </shape>
    </item>
</layer-list>
