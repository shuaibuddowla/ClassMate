<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#101B33"
                android:centerColor="#0B2248"
                android:endColor="#123A72" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#335F9DF7" />
        </shape>
    </item>
    <item android:right="0dp" android:left="230dp">
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#33FBBF24"
                android:endColor="#00123A72" />
            <corners android:topRightRadius="22dp" android:bottomRightRadius="22dp" />
        </shape>
    </item>
</layer-list>
