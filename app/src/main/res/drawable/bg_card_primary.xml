<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glow shadow layer -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#143B82F6"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Main card background -->
    <item
        android:bottom="2dp">
        <shape>
            <solid android:color="@color/cm_card"/>
            <corners android:radius="24dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/cm_border"/>
        </shape>
    </item>

</layer-list>
