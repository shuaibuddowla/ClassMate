<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_card_primary.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft glow/shadow layer (Blue) -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#082563EB"/> <!-- 3% opacity blue -->
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Main card background -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="@color/cm_card"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="1dp"
                android:color="#1A2563EB"/> <!-- 10% opacity blue -->
        </shape>
    </item>
</layer-list>
