<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="24dp"
                android:bottomRightRadius="24dp" />
            <solid android:color="@color/cm_bottom_nav_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/cm_border" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="27dp"
                android:topRightRadius="27dp"
                android:bottomLeftRadius="23dp"
                android:bottomRightRadius="23dp" />
            <solid android:color="@color/cm_surface_glass" />
        </shape>
    </item>
</layer-list>
