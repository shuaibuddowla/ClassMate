<?xml version="1.0" encoding="utf-8"?>
<!-- res/values/attrs.xml -->
<resources>

    <!-- Custom attributes for GlassCardView -->
    <declare-styleable name="GlassCardView">
        <!-- Glass tint color. Applied as an overlay on the dark base. Default: transparent. -->
        <attr name="glassTint" format="color" />

        <!-- Corner radius of the glass card shape (dp). Default: 20dp. -->
        <attr name="glassCornerRadius" format="dimension" />

        <!-- Alpha (0–255) of the top shine highlight gradient. Default: 30. -->
        <attr name="glassHighlightAlpha" format="integer" />

        <!-- Alpha (0–255) of the glass base background. Default: 200. -->
        <attr name="glassBaseAlpha" format="integer" />

        <!-- Whether to show a left-edge shimmer line accent. Default: false. -->
        <attr name="glassShowAccentLine" format="boolean" />

        <!-- Accent line color for the left edge highlight. Default: #3B82F6 blue. -->
        <attr name="glassAccentColor" format="color" />
    </declare-styleable>

</resources>
