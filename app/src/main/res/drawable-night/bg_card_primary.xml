<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#183B82F6" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:bottom="2dp">
        <shape>
            <solid android:color="@color/cm_surface" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#333B82F6" />
        </shape>
    </item>
</layer-list>
