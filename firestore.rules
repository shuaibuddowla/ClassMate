rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isLoggedIn() && exists(userDocPath());
    }

    function getUser() {
      return userExists()
        ? get(userDocPath()).data
        : null;
    }

    function getRole() {
      return userExists() ? getUser().role : null;
    }

    function isSuperAdmin() {
      return isLoggedIn() && getRole() == "superadmin";
    }

    function isAdmin() {
      return isLoggedIn() &&
        (getRole() == "admin" || getRole() == "superadmin");
    }

    function hasPermission(permissionKey) {
      return userExists() &&
        "permissions" in getUser() &&
        permissionKey in getUser().permissions &&
        getUser().permissions[permissionKey] == true;
    }

    function canPostNotice() {
      return isAdmin() || hasPermission("canPostNotices");
    }

    function canSendClassCancel() {
      return isAdmin() || hasPermission("canSendClassCancel");
    }

    function canEditTimetable() {
      return isAdmin() || hasPermission("canEditTimetable");
    }

    function canManageUsers() {
      return isSuperAdmin() || hasPermission("canManageUsers");
    }

    function canManageAdmins() {
      return isSuperAdmin() || hasPermission("canManageAdmins");
    }

    function canUploadPdf() {
      return isLoggedIn() &&
        (
          isAdmin() ||
          hasPermission("canUploadPDF") ||
          hasPermission("canUploadLibrary")
        );
    }

    function isStudent() {
      return isLoggedIn() && getRole() == "student";
    }

    function noticeLikeId(noticeId) {
      return noticeId + "_" + request.auth.uid;
    }

    function commentLikeId(commentId) {
      return commentId + "_" + request.auth.uid;
    }

    function reminderId(noticeId) {
      return noticeId + "_" + request.auth.uid;
    }

    function ownUserDoc() {
      return isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    function isFriendsPublic() {
      return exists(/databases/$(database)/documents/config/friends) &&
        get(/databases/$(database)/documents/config/friends).data.isPublic == true;
    }

    function validStudentIdForAuthCreate(request) {
      return !("studentId" in request.resource.data) ||
        request.resource.data.studentId == "" ||
        (
          request.resource.data.studentId is string &&
          request.resource.data.studentId.matches("^[A-Z]{2,4}[0-9]{5}$")
        );
    }

    function validStudentIdValue(studentId) {
      return studentId is string && studentId.matches("^[A-Z]{2,4}[0-9]{5}$");
    }

    function noElevatedCreatePermissions(request) {
      return !("permissions" in request.resource.data) ||
        (
          request.resource.data.permissions is map
          && request.resource.data.permissions.keys().hasOnly([
            "canCreatePolls",
            "canEditTimetable",
            "canPostNotices",
            "canSendClassCancel",
            "canUploadPDF",
            "canUploadLibrary",
            "canUploadResult",
            "canUploadSeatPlan",
            "canManageUsers",
            "canManageAdmins"
          ])
          && (!("canCreatePolls" in request.resource.data.permissions) ||
              request.resource.data.permissions.canCreatePolls == false)
          && (!("canEditTimetable" in request.resource.data.permissions) ||
              request.resource.data.permissions.canEditTimetable == false)
          && (!("canPostNotices" in request.resource.data.permissions) ||
              request.resource.data.permissions.canPostNotices == false)
          && (!("canUploadPDF" in request.resource.data.permissions) ||
              request.resource.data.permissions.canUploadPDF == false)
          && (!("canUploadLibrary" in request.resource.data.permissions) ||
              request.resource.data.permissions.canUploadLibrary == false)
          && (!("canSendClassCancel" in request.resource.data.permissions) ||
              request.resource.data.permissions.canSendClassCancel == false)
          && (!("canUploadSeatPlan" in request.resource.data.permissions) ||
              request.resource.data.permissions.canUploadSeatPlan == false)
          && (!("canUploadResult" in request.resource.data.permissions) ||
              request.resource.data.permissions.canUploadResult == false)
          && (!("canManageUsers" in request.resource.data.permissions) ||
              request.resource.data.permissions.canManageUsers == false)
          && (!("canManageAdmins" in request.resource.data.permissions) ||
              request.resource.data.permissions.canManageAdmins == false)
        );
    }

    function validOwnUserCreate(userId, request) {
      return isLoggedIn()
        && request.auth.uid == userId
        && (!("uid" in request.resource.data) || request.resource.data.uid == userId)
        && (!("name" in request.resource.data) ||
            (request.resource.data.name is string &&
             request.resource.data.name.size() <= 80))
        && (!("fullName" in request.resource.data) ||
            (request.resource.data.fullName is string &&
             request.resource.data.fullName.size() <= 80))
        && (!("email" in request.resource.data) ||
            (request.resource.data.email is string &&
             request.resource.data.email.size() <= 120))
        && validStudentIdForAuthCreate(request)
        && (!("department" in request.resource.data) ||
            (request.resource.data.department is string &&
             request.resource.data.department.size() <= 12))
        && (!("role" in request.resource.data) || request.resource.data.role == "student")
        && (!("authProvider" in request.resource.data) ||
            request.resource.data.authProvider in ["email", "google"])
        && noElevatedCreatePermissions(request);
    }

    function permissionStaysFalseOrUnchanged(permissionKey) {
      return !(permissionKey in request.resource.data.permissions) ||
        request.resource.data.permissions[permissionKey] == false ||
        (
          "permissions" in resource.data &&
          permissionKey in resource.data.permissions &&
          resource.data.permissions[permissionKey] == true &&
          request.resource.data.permissions[permissionKey] == true
        );
    }

    function existingTruePermissionPreserved(permissionKey) {
      return !("permissions" in resource.data) ||
        !(permissionKey in resource.data.permissions) ||
        resource.data.permissions[permissionKey] != true ||
        (
          permissionKey in request.resource.data.permissions &&
          request.resource.data.permissions[permissionKey] == true
        );
    }

    function validOwnPermissionsUpdate() {
      return !("permissions" in request.resource.data.diff(resource.data).affectedKeys()) ||
        (
          request.resource.data.permissions is map
          && request.resource.data.permissions.keys().hasOnly([
            "canCreatePolls",
            "canEditTimetable",
            "canPostNotices",
            "canSendClassCancel",
            "canUploadPDF",
            "canUploadLibrary",
            "canUploadResult",
            "canUploadSeatPlan",
            "canManageUsers",
            "canManageAdmins"
          ])
          && permissionStaysFalseOrUnchanged("canCreatePolls")
          && permissionStaysFalseOrUnchanged("canEditTimetable")
          && permissionStaysFalseOrUnchanged("canPostNotices")
          && permissionStaysFalseOrUnchanged("canSendClassCancel")
          && permissionStaysFalseOrUnchanged("canUploadPDF")
          && permissionStaysFalseOrUnchanged("canUploadLibrary")
          && permissionStaysFalseOrUnchanged("canUploadResult")
          && permissionStaysFalseOrUnchanged("canUploadSeatPlan")
          && permissionStaysFalseOrUnchanged("canManageUsers")
          && permissionStaysFalseOrUnchanged("canManageAdmins")
          && existingTruePermissionPreserved("canCreatePolls")
          && existingTruePermissionPreserved("canEditTimetable")
          && existingTruePermissionPreserved("canPostNotices")
          && existingTruePermissionPreserved("canSendClassCancel")
          && existingTruePermissionPreserved("canUploadPDF")
          && existingTruePermissionPreserved("canUploadLibrary")
          && existingTruePermissionPreserved("canUploadResult")
          && existingTruePermissionPreserved("canUploadSeatPlan")
          && existingTruePermissionPreserved("canManageUsers")
          && existingTruePermissionPreserved("canManageAdmins")
        );
    }

    function validOwnUserUpdate(userId) {
      return isLoggedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "uid",
          "createdAt",
          "name",
          "fullName",
          "email",
          "photoUrl",
          "studentId",
          "department",
          "authProvider",
          "updatedAt",
          "phone",
          "bloodGroup",
          "homeDistrict",
          "address",
          "oneSignalPlayerId",
          "permissions",
          "role",
          "favoriteSubjects",
          "favoritePdfIds"
        ])
        && (!("uid" in request.resource.data) || request.resource.data.uid == userId)
        && (!("role" in request.resource.data.diff(resource.data).affectedKeys()) ||
            (!("role" in resource.data) && request.resource.data.role == "student"))
        && (!("name" in request.resource.data) ||
            (request.resource.data.name is string &&
             request.resource.data.name.size() <= 80))
        && (!("fullName" in request.resource.data) ||
            (request.resource.data.fullName is string &&
             request.resource.data.fullName.size() <= 80))
        && (!("email" in request.resource.data) ||
            (request.resource.data.email is string &&
             request.resource.data.email.size() <= 120))
        && (!("studentId" in request.resource.data) ||
            request.resource.data.studentId == "" ||
            (request.resource.data.studentId is string &&
             request.resource.data.studentId.matches("^[A-Z]{2,4}[0-9]{5}$")))
        && (!("department" in request.resource.data) ||
            (request.resource.data.department is string &&
             request.resource.data.department.size() <= 12))
        && (!("authProvider" in request.resource.data) ||
            request.resource.data.authProvider in ["email", "google"])
        && validOwnPermissionsUpdate();
    }

    function validLibraryCourseType() {
      return request.resource.data.courseType in ["regular", "lab", "other"];
    }

    function validLibraryFileType() {
      return request.resource.data.fileType in [
        "pdf",
        "ppt",
        "pptx",
        "doc",
        "docx",
        "xls",
        "xlsx",
        "image",
        "zip",
        "other"
      ];
    }

    function validLibraryProvider() {
      return request.resource.data.provider in ["github_releases", "external_link"];
    }

    function validLibraryMimeType() {
      return request.resource.data.mimeType in [
        "application/pdf",
        "application/vnd.ms-powerpoint",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.ms-excel",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "image/png",
        "image/jpeg",
        "image/webp",
        "application/zip",
        "application/octet-stream"
      ];
    }

    function validLibraryBaseFields() {
      return request.resource.data.keys().hasOnly([
        "title",
        "subject",
        "courseCode",
        "courseType",
        "description",
        "fileType",
        "mimeType",
        "sizeBytes",
        "provider",
        "downloadUrl",
        "driveUrl",
        "githubAssetId",
        "githubAssetName",
        "uploadedByUid",
        "uploadedByName",
        "uploadedBy",
        "createdAt",
        "updatedAt",
        "timestamp",
        "downloadCount",
        "isDeleted"
      ])
      && request.resource.data.title is string
      && request.resource.data.title.size() > 0
      && request.resource.data.title.size() <= 180
      && request.resource.data.subject is string
      && request.resource.data.subject.size() > 0
      && request.resource.data.subject.size() <= 120
      && request.resource.data.courseCode is string
      && request.resource.data.courseCode.size() > 0
      && request.resource.data.courseCode.size() <= 40
      && validLibraryCourseType()
      && validLibraryFileType()
      && validLibraryMimeType()
      && validLibraryProvider()
      && request.resource.data.sizeBytes is int
      && request.resource.data.sizeBytes >= 0
      && request.resource.data.sizeBytes <= 104857600
      && request.resource.data.downloadUrl is string
      && request.resource.data.downloadUrl.size() > 0
      && request.resource.data.downloadUrl.size() <= 2000
      && request.resource.data.githubAssetId is int
      && request.resource.data.githubAssetId >= 0
      && request.resource.data.githubAssetName is string
      && request.resource.data.githubAssetName.size() <= 255
      && request.resource.data.uploadedByUid == request.auth.uid
      && request.resource.data.uploadedByName is string
      && request.resource.data.uploadedByName.size() <= 80
      && request.resource.data.uploadedBy is string
      && request.resource.data.uploadedBy.size() <= 80
      && request.resource.data.downloadCount == 0
      && request.resource.data.isDeleted == false;
    }

    function validLibraryGitHubCreate() {
      return request.resource.data.provider == "github_releases"
        && request.resource.data.downloadUrl.matches("^https://github\\.com/.*/releases/download/.*$")
        && request.resource.data.githubAssetId > 0
        && request.resource.data.githubAssetName.size() > 0
        && (
          !("driveUrl" in request.resource.data) ||
          request.resource.data.driveUrl == ""
        );
    }

    function validLibraryExternalLinkCreate() {
      return request.resource.data.provider == "external_link"
        && request.resource.data.githubAssetId == 0
        && request.resource.data.githubAssetName == "";
    }

    function validLibraryCreate() {
      return canUploadPdf()
        && validLibraryBaseFields()
        && (validLibraryGitHubCreate() || validLibraryExternalLinkCreate())
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.timestamp == request.time;
    }

    function validLibraryDownloadCountUpdate() {
      return isLoggedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["downloadCount"])
        && request.resource.data.downloadCount is int
        && request.resource.data.downloadCount == resource.data.downloadCount + 1;
    }

    function validLibrarySoftDeleteUpdate() {
      return canUploadPdf()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isDeleted", "updatedAt"])
        && request.resource.data.isDeleted == true
        && request.resource.data.updatedAt == request.time;
    }

    function validResourceNoticeCreate() {
      return canUploadPdf()
        && request.resource.data.keys().hasOnly([
          "title",
          "body",
          "postedBy",
          "timestamp",
          "isResource",
          "subject",
          "pdfId"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 180
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.postedBy is string
        && request.resource.data.postedBy.size() <= 80
        && request.resource.data.timestamp == request.time
        && request.resource.data.isResource == true
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 120
        && request.resource.data.pdfId is string
        && request.resource.data.pdfId.size() > 0;
    }

    function validClassCancelPeriodUpdate() {
      return canSendClassCancel()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "isCancelled",
          "cancelDate"
        ])
        && request.resource.data.isCancelled == true
        && request.resource.data.cancelDate is string
        && request.resource.data.cancelDate.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$");
    }

    function validAcademicCalendarExceptionBase() {
      return request.resource.data.keys().hasOnly([
          "title",
          "type",
          "startDate",
          "endDate",
          "scope",
          "reason",
          "isActive",
          "showHolidayBriefing",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.type in ["VACATION", "HOLIDAY", "CLASS_SUSPENDED"]
        && request.resource.data.startDate is string
        && request.resource.data.startDate.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$")
        && request.resource.data.endDate is string
        && request.resource.data.endDate.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$")
        && request.resource.data.endDate >= request.resource.data.startDate
        && request.resource.data.scope == "ALL_CLASSES"
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.isActive is bool
        && request.resource.data.showHolidayBriefing is bool
        && request.resource.data.createdBy is string;
    }

    function validAcademicCalendarExceptionCreate() {
      return canEditTimetable()
        && validAcademicCalendarExceptionBase()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validAcademicCalendarExceptionUpdate() {
      return canEditTimetable()
        && validAcademicCalendarExceptionBase()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function validManagerUserUpdate() {
      return canManageUsers()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "role",
          "permissions"
        ])
        && (
          !("role" in request.resource.data.diff(resource.data).affectedKeys()) ||
          request.resource.data.role in ["student", "admin", "superadmin"]
        )
        && (
          !("permissions" in request.resource.data.diff(resource.data).affectedKeys()) ||
          (
            request.resource.data.permissions is map &&
            request.resource.data.permissions.keys().hasOnly([
              "canCreatePolls",
              "canEditTimetable",
              "canPostNotices",
              "canSendClassCancel",
              "canUploadPDF",
              "canUploadLibrary",
              "canUploadResult",
              "canUploadSeatPlan",
              "canManageUsers",
              "canManageAdmins"
            ])
          )
        )
        && (
          canManageAdmins() ||
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"])
        )
        && (
          canManageAdmins() ||
          !("permissions" in request.resource.data) ||
          (
            (
              !("permissions" in resource.data) ||
              !("canManageAdmins" in resource.data.permissions) ||
              !("canManageAdmins" in request.resource.data.permissions) ||
              request.resource.data.permissions.canManageAdmins == resource.data.permissions.canManageAdmins
            )
          )
        );
    }

    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if isLoggedIn() && isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || canManageUsers() || isFriendsPublic());

      allow create: if validOwnUserCreate(userId, request);

      allow update: if validManagerUserUpdate() || validOwnUserUpdate(userId);

      allow delete: if isLoggedIn() && (isSuperAdmin() || canManageUsers());

      match /countdowns/{countdownId} {
        allow read: if isLoggedIn() && request.auth.uid == userId;
        allow create, update: if isLoggedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            "assignmentId",
            "subject",
            "topic",
            "submissionDate",
            "type",
            "addedAt"
          ])
          && request.resource.data.assignmentId is string
          && request.resource.data.subject is string
          && request.resource.data.topic is string
          && request.resource.data.submissionDate is string
          && request.resource.data.type in ["assignment", "deadline", "exam", "quiz", "other"]
          && request.resource.data.addedAt == request.time;
        allow delete: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    match /student_id_lookup/{studentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && studentId.matches("^[A-Z]{2,4}[0-9]{5}$")
        && request.resource.data.keys().hasOnly(["uid", "email"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update, delete: if request.auth != null &&
        (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /assignments/{assignmentId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    match /timetable/{day}/periods/{periodId} {
      allow read: if isLoggedIn();
      allow create, delete: if canEditTimetable();
      allow update: if canEditTimetable() || validClassCancelPeriodUpdate();
    }

    match /academic_calendar_exceptions/{exceptionId} {
      allow read: if isLoggedIn();
      allow create: if validAcademicCalendarExceptionCreate();
      allow update: if validAcademicCalendarExceptionUpdate();
      allow delete: if canEditTimetable();
    }

    match /notices/{noticeId} {
      allow read: if isLoggedIn();
      allow create: if canPostNotice() || validResourceNoticeCreate() ||
        (canSendClassCancel() && request.resource.data.isCancel == true);
      allow update, delete: if canPostNotice();
    }

    match /notice_likes/{likeId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && likeId == noticeLikeId(request.resource.data.noticeId)
        && request.resource.data.keys().hasOnly(["noticeId", "userId", "createdAt"])
        && request.resource.data.noticeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow delete: if ownUserDoc();
      allow update: if false;
    }

    match /notice_comments/{commentId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.resource.data.keys().hasOnly([
          "commentId",
          "noticeId",
          "userId",
          "userName",
          "userAvatar",
          "content",
          "parentCommentId",
          "likeCount",
          "replyCount",
          "createdAt",
          "updatedAt",
          "isDeleted"
        ])
        && request.resource.data.commentId == commentId
        && request.resource.data.noticeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 80
        && request.resource.data.userAvatar is string
        && request.resource.data.userAvatar.size() <= 500
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && (
          request.resource.data.parentCommentId == null ||
          request.resource.data.parentCommentId is string
        )
        && request.resource.data.likeCount == 0
        && request.resource.data.replyCount == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.isDeleted == false;

      allow update: if isLoggedIn() &&
        (
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "content",
              "isDeleted",
              "updatedAt"
            ])
            && request.resource.data.isDeleted == true
            && request.resource.data.content == ""
            && request.resource.data.updatedAt == request.time
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeCount"])
            && request.resource.data.likeCount is int
            && request.resource.data.likeCount >= 0
            && (
              (
                request.resource.data.likeCount == resource.data.likeCount + 1
                && !exists(/databases/$(database)/documents/comment_likes/$(commentLikeId(commentId)))
                && existsAfter(/databases/$(database)/documents/comment_likes/$(commentLikeId(commentId)))
              )
              ||
              (
                request.resource.data.likeCount == resource.data.likeCount - 1
                && exists(/databases/$(database)/documents/comment_likes/$(commentLikeId(commentId)))
                && !existsAfter(/databases/$(database)/documents/comment_likes/$(commentLikeId(commentId)))
              )
            )
          )
          || isAdmin()
        );

      allow delete: if isAdmin();
    }

    match /comment_likes/{likeId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && likeId == commentLikeId(request.resource.data.commentId)
        && request.resource.data.keys().hasOnly(["commentId", "userId", "createdAt"])
        && request.resource.data.commentId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow delete: if ownUserDoc();
      allow update: if false;
    }

    match /user_notice_reminders/{reminderDocId} {
      allow create: if isLoggedIn()
        && reminderDocId == reminderId(request.resource.data.noticeId)
        && request.resource.data.keys().hasOnly([
          "noticeId",
          "userId",
          "reminderAt",
          "createdAt",
          "isDone"
        ])
        && request.resource.data.noticeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.reminderAt is timestamp
        && request.resource.data.createdAt == request.time
        && request.resource.data.isDone == false;

      allow read, update, delete: if ownUserDoc();
    }

    match /notice_shares/{shareId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /polls/{pollId} {
      function pollDoc() {
        return get(/databases/$(database)/documents/polls/$(pollId)).data;
      }

      function pollIsOpen() {
        return exists(/databases/$(database)/documents/polls/$(pollId)) &&
          pollDoc().isActive == true &&
          pollDoc().expiresAt > request.time;
      }

      function validVotePayload() {
        return request.resource.data.keys()
          .hasOnly(["option", "selectedOptions", "createdAt", "updatedAt"]) &&
          request.resource.data.option is string &&
          request.resource.data.selectedOptions is list &&
          request.resource.data.selectedOptions.size() > 0 &&
          request.resource.data.selectedOptions.size() <= 12 &&
          (pollDoc().allowMultipleAnswers == true ||
            request.resource.data.selectedOptions.size() == 1);
      }

      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();

      match /votes/{voteId} {
        allow read: if isLoggedIn();

        allow create: if isLoggedIn() &&
          request.auth.uid == voteId &&
          pollIsOpen() &&
          validVotePayload() &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time;

        allow update: if isLoggedIn() &&
          request.auth.uid == voteId &&
          pollIsOpen() &&
          validVotePayload() &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.updatedAt == request.time;

        allow delete: if isAdmin();
      }
    }

    match /pdfs/{pdfId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    match /library_files/{fileId} {
      allow read: if isLoggedIn() && resource.data.isDeleted != true;
      allow create: if validLibraryCreate();
      allow update: if isAdmin() || validLibraryDownloadCountUpdate() || validLibrarySoftDeleteUpdate();
      allow delete: if isSuperAdmin();
    }

    match /results/{resultId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    match /seatplans/{planId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    match /attendance_sessions/{sessionId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow read: if isAdmin() ||
        (isLoggedIn() && resource.data.studentUid == request.auth.uid);
      allow create: if isLoggedIn() &&
        request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /attendance_sheets/{sheetId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /notification_queue/{docId} {
      allow read: if isAdmin() ||
        (isLoggedIn() && resource.data.studentUid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isLoggedIn() &&
         resource.data.studentUid == request.auth.uid &&
         request.resource.data.diff(resource.data)
           .affectedKeys().hasOnly(["sent"]));
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
